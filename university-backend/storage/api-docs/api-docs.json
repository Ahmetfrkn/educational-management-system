    "paths": {
        "/api/assignments": {
            "post": {
                "tags": [
                    "Assignments"
                ],
                "summary": "Create a new assignment",
                "description": "CREATE ASSIGNMENT",
                "operationId": "fa0f5017d8cb75a482885699a5d25e49",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "course_id",
                                    "title",
                                    "due_at",
                                    "max_points"
                                ],
                                "properties": {
                                    "course_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Homework 1"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Solve questions 1-5 from the book."
                                    },
                                    "due_at": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-02-15T23:59:59Z"
                                    },
                                    "max_points": {
                                        "type": "integer",
                                        "example": 100
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Assignment created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "assignment_id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "course_id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "title": {
                                            "type": "string",
                                            "example": "Homework 1"
                                        },
                                        "max_points": {
                                            "type": "integer",
                                            "example": 100
                                        },
                                        "due_at": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "created_at": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "updated_at": {
                                            "type": "string",
                                            "format": "date-time"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
